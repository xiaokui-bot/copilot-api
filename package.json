{
  "name": "@xiaokui/copilot-api",
  "version": "0.7.1",
  "description": "Turn GitHub Copilot into OpenAI/Anthropic API compatible server. Usable with Claude Code!",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "homepage": "https://github.com/suxf/copilot-api",
  "bugs": "https://github.com/suxf/copilot-api/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suxf/copilot-api.git"
  },
  "author": "suxf",
  "type": "module",
  "bin": {
    "copilot-api": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch ./src/main.ts",
    "knip": "knip",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "npm run build",
    "prepare": "simple-git-hooks",
    "release": "bumpp && npm publish --access public",
    "start": "NODE_ENV=production node ./dist/main.js",
    "typecheck": "tsc",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "npm run lint -- --fix"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "proxy-from-env": "^1.1.0",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.16.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@echristian/eslint-config": "^0.0.54",
    "@types/node": "^20.11.0",
    "@types/proxy-from-env": "^1.0.4",
    "bumpp": "^10.2.3",
    "eslint": "^9.37.0",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.3",
    "prettier-plugin-packagejson": "^2.5.19",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.15.6",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
